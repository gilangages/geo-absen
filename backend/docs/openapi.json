{
  "openapi": "3.0.3",
  "info": {
    "title": "Geo Absen API",
    "description": "API Documentation untuk aplikasi Absensi Karyawan (Backend Laravel & Frontend Flutter). \n\n**Catatan Penting untuk Frontend Flutter:**\n1. Pastikan selalu mengirim header `Accept: application/json` pada setiap request API agar jika terjadi error, response akan selalu dalam bentuk JSON (bukan redirect ke halaman web login).\n2. Untuk endpoint yang terkunci, Flutter harus mengirim token di header: `Authorization: Bearer <token_aktif>`.\n3. Khusus untuk endpoint `POST /api/attendances`, `POST /api/leaves`, dan `PATCH /api/users/current`, karena mengirimkan file (foto), pastikan menggunakan `Content-Type: multipart/form-data` dari sisi Flutter.",
    "version": "1.0.0",
    "contact": {
      "name": "Gilang Abdian Anggara",
      "email": "qbdian@gmail.com"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8000"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "Token"
      }
    }
  },
  "paths": {
    "/api/auth/register": {
      "post": {
        "summary": "Pendaftaran Karyawan Baru (Demo)",
        "tags": [
          "Auth & User"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  },
                  "password_confirmation": {
                    "type": "string"
                  },
                  "position": {
                    "type": "string"
                  }
                },
                "required": [
                  "name",
                  "email",
                  "password",
                  "position"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Berhasil."
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Login Karyawan",
        "tags": [
          "Auth & User"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Berhasil."
          }
        }
      }
    },
    "/api/auth/logout": {
      "delete": {
        "summary": "Logout",
        "tags": [
          "Auth & User"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Berhasil."
          }
        }
      }
    },
    "/api/users/current": {
      "get": {
        "summary": "Data Profil Karyawan",
        "description": "Mengambil data profil karyawan yang sedang login.",
        "tags": [
          "Auth & User"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Data profil berhasil diambil."
          }
        }
      },
      "post": {
        "summary": "Update Profil Karyawan (PATCH Spoofing)",
        "description": "Mengupdate data diri karyawan. Karena menyertakan file (avatar), Flutter HARUS menggunakan method POST namun menambahkan field `_method: PATCH` di dalam FormData.",
        "tags": [
          "Auth & User"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "_method": {
                    "type": "string",
                    "example": "PATCH",
                    "description": "Wajib diisi 'PATCH' agar Laravel mengenali ini sebagai request update."
                  },
                  "name": {
                    "type": "string",
                    "example": "Budi Santoso"
                  },
                  "email": {
                    "type": "string",
                    "example": "budi@kantor.com"
                  },
                  "password": {
                    "type": "string",
                    "description": "Opsional, isi jika ingin ganti password."
                  },
                  "password_confirmation": {
                    "type": "string",
                    "description": "Wajib diisi jika password diisi."
                  },
                  "avatar": {
                    "type": "string",
                    "format": "binary",
                    "description": "Opsional, file gambar foto profil baru."
                  }
                },
                "required": [
                  "_method"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Profil berhasil diperbarui.",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "message": "Profil berhasil diperbarui.",
                  "data": {
                    "id": 1,
                    "name": "Budi Santoso Baru",
                    "email": "budi@kantor.com",
                    "avatar_url": "https://..."
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validasi gagal.",
            "content": {
              "application/json": {
                "example": {
                  "success": false,
                  "message": "Data tidak valid.",
                  "errors": {
                    "email": [
                      "Email sudah digunakan oleh orang lain."
                    ]
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/attendances": {
      "get": {
        "summary": "Riwayat Absensi",
        "tags": [
          "Attendances"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Berhasil."
          }
        }
      },
      "post": {
        "summary": "Kirim Data Absensi",
        "tags": [
          "Attendances"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "201": {
            "description": "Berhasil."
          }
        }
      }
    },
    "/api/attendances/today": {
      "get": {
        "summary": "Cek Status Hari Ini",
        "tags": [
          "Attendances"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Berhasil."
          }
        }
      }
    },
    "/api/leaves": {
      "get": {
        "summary": "Riwayat Izin/Cuti",
        "tags": [
          "Leaves"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Berhasil."
          }
        }
      },
      "post": {
        "summary": "Ajukan Izin/Cuti",
        "tags": [
          "Leaves"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "201": {
            "description": "Berhasil."
          }
        }
      }
    }
  }
}
